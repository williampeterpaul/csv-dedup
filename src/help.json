{
  "name": "csv-dedup",
  "about": "Merge, deduplicate, and combine CSV files",
  "commands": {
    "merge": {
      "about": "Join multiple CSVs on key columns (outer, inner, left, exclude, unique, overlap)",
      "usage": "csv-dedup merge <file1.csv> [file2.csv ...] [options]",
      "options": [
        { "flag": "-k, --keys <cols>", "about": "Comma-separated key column(s) for matching rows (required)" },
        { "flag": "-m, --mode <mode>", "about": "Join mode: outer, inner, left, exclude, unique, overlap (default: outer)" },
        { "flag": "-c, --columns <cols>", "about": "Comma-separated columns to include in output (default: all)" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <first-file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup merge a.csv b.csv -k domain,name",
        "csv-dedup merge a.csv b.csv -k id -m inner",
        "csv-dedup merge source.csv extra.csv -k id -m left",
        "csv-dedup merge source.csv blocklist.csv -k email -m exclude",
        "csv-dedup merge a.csv b.csv -k id -c id,name,email -o merged.csv"
      ]
    },
    "stats": {
      "about": "Print column fill rates, unique counts, and top values",
      "usage": "csv-dedup stats <file.csv>",
      "options": [
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup stats leads.csv"
      ]
    },
    "filter": {
      "about": "Filter rows by expression",
      "usage": "csv-dedup filter <file.csv> --expr <expression> [options]",
      "options": [
        { "flag": "-e, --expr <expr>", "about": "Filter expression (repeatable, ANDed). See syntax below" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup filter leads.csv -e \"country=US\"",
        "csv-dedup filter leads.csv -e \"email!=''\" -e \"country:US,UK,DE\"",
        "csv-dedup filter leads.csv -e \"name~corp AND country!=''\" -o filtered.csv"
      ]
    },
    "split": {
      "about": "Split a CSV into fixed-size chunks",
      "usage": "csv-dedup split <file.csv> -n <rows>",
      "options": [
        { "flag": "-n, --rows <n>", "about": "Max rows per output file (required)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup split leads.csv -n 1000",
        "csv-dedup split contacts.csv -n 500"
      ]
    },
    "norm": {
      "about": "Normalize column values (trim, lowercase, domain cleanup)",
      "usage": "csv-dedup norm <file.csv> [options]",
      "options": [
        { "flag": "-c, --columns <cols>", "about": "Comma-separated columns to normalize (default: all)" },
        { "flag": "--ascii", "about": "Transliterate accents to ASCII and strip non-printable characters" },
        { "flag": "--domain", "about": "Strip http(s)://, www., and trailing slashes" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup norm leads.csv -c email,domain",
        "csv-dedup norm leads.csv -c website --domain -o clean.csv"
      ]
    },
    "format": {
      "about": "Transform column values (casing, truncate, strip)",
      "usage": "csv-dedup format <file.csv> [options]",
      "options": [
        { "flag": "-c, --columns <cols>", "about": "Comma-separated columns to format (default: all)" },
        { "flag": "--upper", "about": "UPPERCASE" },
        { "flag": "--lower", "about": "lowercase" },
        { "flag": "--title", "about": "Title Case" },
        { "flag": "-t, --truncate <n>", "about": "Cap values at N characters" },
        { "flag": "--strip <chars>", "about": "Remove specific characters (e.g. \"#$\")" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup format leads.csv -c name --truncate 50",
        "csv-dedup format leads.csv -c notes --strip \"#$\" -o clean.csv"
      ]
    }
  }
}
