{
  "name": "csv-dedup",
  "about": "Merge, deduplicate, and transform CSV files",
  "commands": {
    "merge": {
      "about": "Join multiple CSVs on key columns (outer, inner, left, exclude, unique, overlap)",
      "usage": "csv-dedup merge <file1.csv> [file2.csv ...] [options]",
      "options": [
        { "flag": "-k, --keys <cols>", "about": "Comma-separated key column(s) for matching rows (required)" },
        { "flag": "-m, --mode <mode>", "about": "Join mode: outer, inner, left, exclude, unique, overlap (default: outer)" },
        { "flag": "-c, --columns <cols>", "about": "Comma-separated columns to include in output (default: all)" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <first-file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup merge a.csv b.csv -k domain,name",
        "csv-dedup merge a.csv b.csv -k id -m inner",
        "csv-dedup merge source.csv extra.csv -k id -m left",
        "csv-dedup merge source.csv blocklist.csv -k email -m exclude",
        "csv-dedup merge a.csv b.csv -k id -c id,name,email -o merged.csv"
      ]
    },
    "stats": {
      "about": "Print column fill rates, unique counts, and top values",
      "usage": "csv-dedup stats <file.csv> [options]",
      "options": [
        { "flag": "-e, --expr <expr>", "about": "Filter expression (repeatable, ANDed) — stats for matching rows only" },
        { "flag": "-g, --group <col>", "about": "Group by column and show stats per group" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup stats leads.csv",
        "csv-dedup stats leads.csv -e \"country=US\"",
        "csv-dedup stats leads.csv --group country",
        "csv-dedup stats leads.csv -e \"email!=''\" --group source"
      ]
    },
    "filter": {
      "about": "Filter rows by expression",
      "usage": "csv-dedup filter <file.csv> -e <expr> [options]",
      "options": [
        { "flag": "-e, --expr <expr>", "about": "Filter expression (repeatable, ANDed). See syntax below" },
        { "flag": "-v, --invert", "about": "Invert the filter — keep non-matching rows" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup filter leads.csv -e \"country=US\"",
        "csv-dedup filter leads.csv -e \"email!=''\" -e \"country:US,UK,DE\"",
        "csv-dedup filter leads.csv -e \"name~corp AND country!=''\" -o filtered.csv",
        "csv-dedup filter leads.csv -e \"country:@countries.csv\"",
        "csv-dedup filter leads.csv -e \"email~~@allowlist.txt\"",
        "csv-dedup filter leads.csv -e \"email~~@blocklist.txt\" --invert",
        "csv-dedup filter leads.csv -e \"country=US\" --invert"
      ]
    },
    "split": {
      "about": "Split a CSV into fixed-size chunks",
      "usage": "csv-dedup split <file.csv> -n <rows> [options]",
      "options": [
        { "flag": "-n, --rows <n>", "about": "Max rows per output file (required)" },
        { "flag": "--take <n>", "about": "Only write the first N chunks (--take 1 = head)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup split leads.csv -n 1000",
        "csv-dedup split contacts.csv -n 500",
        "csv-dedup split leads.csv -n 100 --take 1"
      ]
    },
    "format": {
      "about": "Format and normalize column values (trim, collapse spaces, casing, etc.)",
      "usage": "csv-dedup format <file.csv> [options]",
      "options": [
        { "flag": "-c, --columns <cols>", "about": "Comma-separated columns to format (default: all)" },
        { "flag": "--upper", "about": "UPPERCASE" },
        { "flag": "--lower", "about": "lowercase" },
        { "flag": "--title", "about": "Title Case" },
        { "flag": "--ascii", "about": "Transliterate accents to ASCII and strip non-printable characters" },
        { "flag": "--domain", "about": "Strip http(s)://, www., and trailing slashes" },
        { "flag": "-t, --truncate <n>", "about": "Cap values at N characters" },
        { "flag": "--strip <chars>", "about": "Remove specific characters (e.g. \"#$\")" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup format leads.csv -c email,domain",
        "csv-dedup format leads.csv -c name --title --truncate 50",
        "csv-dedup format leads.csv -c website --domain -o clean.csv",
        "csv-dedup format leads.csv -c notes --strip \"#$\" -o clean.csv"
      ]
    },
    "cleave": {
      "about": "Split one column into two on a delimiter",
      "usage": "csv-dedup cleave <file.csv> -c <column> --on <delim> [options]",
      "options": [
        { "flag": "-c, --column <col>", "about": "Column to split (required)" },
        { "flag": "-d, --on <chars>", "about": "Delimiter to split on (required)" },
        { "flag": "--as <left,right>", "about": "Names for the two new columns (default: col_1, col_2)" },
        { "flag": "--last", "about": "Split on last occurrence instead of first" },
        { "flag": "--keep", "about": "Keep the original column alongside the new ones" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup cleave contacts.csv -c full_name --on \" \" --as first,last",
        "csv-dedup cleave leads.csv -c email --on \"@\" --as user,domain",
        "csv-dedup cleave data.csv -c url --on \"://\" --keep -o split.csv"
      ]
    },
    "pick": {
      "about": "Select, reorder, or drop columns",
      "usage": "csv-dedup pick <file.csv> (-c <cols> | --drop <cols>) [options]",
      "options": [
        { "flag": "-c, --columns <cols>", "about": "Comma-separated columns to keep, in order" },
        { "flag": "--drop <cols>", "about": "Comma-separated columns to remove" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup pick leads.csv -c name,email,domain",
        "csv-dedup pick leads.csv --drop notes,internal_id -o clean.csv"
      ]
    },
    "append": {
      "about": "Add or overwrite a column with a literal value",
      "usage": "csv-dedup append <file.csv> --set <col=val> [options]",
      "options": [
        { "flag": "--set <col=val>", "about": "Column name and value (repeatable)" },
        { "flag": "-e, --expr <expr>", "about": "Only apply to rows matching expression (repeatable, ANDed)" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup append leads.csv --set source=linkedin",
        "csv-dedup append leads.csv --set batch=2024-Q1 --set status=new -o tagged.csv",
        "csv-dedup append leads.csv --set status=valid -e \"email~/^[^@]+@[^@]+\\.[^@]+$/\""
      ]
    },
    "join": {
      "about": "Concatenate columns into a new column (inverse of cleave)",
      "usage": "csv-dedup join <file.csv> --from <cols> --as <name> [options]",
      "options": [
        { "flag": "--from <cols>", "about": "Comma-separated source columns (required)" },
        { "flag": "--glue <str>", "about": "Separator between values (default: empty)" },
        { "flag": "--as <name>", "about": "Name for the new column (required)" },
        { "flag": "--drop", "about": "Remove source columns after joining" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup join contacts.csv --from first,last --glue \" \" --as full_name",
        "csv-dedup join data.csv --from city,state,zip --glue \", \" --as address --drop"
      ]
    },
    "sort": {
      "about": "Sort rows by a column",
      "usage": "csv-dedup sort <file.csv> [-c <column>] [options]",
      "options": [
        { "flag": "-c, --column <col>", "about": "Column to sort by (default: first column)" },
        { "flag": "-d, --desc", "about": "Sort descending" },

        { "flag": "-o, --output <path>", "about": "Output file path (default: <file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup sort leads.csv -c domain",
        "csv-dedup sort leads.csv -c score -n -d",
        "csv-dedup sort leads.csv -o sorted.csv"
      ]
    },
    "repeat": {
      "about": "Duplicate every row N times",
      "usage": "csv-dedup repeat <file.csv> [-n <times>] [options]",
      "options": [
        { "flag": "-n, --times <n>", "about": "Number of copies (default: 2)" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup repeat leads.csv",
        "csv-dedup repeat leads.csv -n 3 -o tripled.csv"
      ]
    },
    "unique": {
      "about": "Deduplicate rows by key columns, optionally only where an expression matches",
      "usage": "csv-dedup unique <file.csv> -k <cols> [options]",
      "options": [
        { "flag": "-k, --keys <cols>", "about": "Comma-separated key column(s) for dedup (required)" },
        { "flag": "-e, --expr <expr>", "about": "Only dedup rows matching expression; non-matching rows are kept as-is (repeatable, ANDed)" },
        { "flag": "-c, --columns <cols>", "about": "Comma-separated columns to include in output (default: all)" },
        { "flag": "-o, --output <path>", "about": "Output file path (default: <file>.out.csv)" },
        { "flag": "-h, --help", "about": "Show this help" }
      ],
      "examples": [
        "csv-dedup unique leads.csv -k email",
        "csv-dedup unique leads.csv -k name -e \"name.len>=6\"",
        "csv-dedup unique leads.csv -k domain -e \"domain!=''\" -o deduped.csv"
      ]
    }
  }
}
